# Quran Reels Generator — environment variables
# ===============================================
# Copy this file to `.env` and uncomment / edit the lines you want to override.
# The `.env` file is git-ignored.  All variables use the `QURAN_` prefix so they
# don't collide with other apps in the same shell.
#
# When a variable is unset (or commented out), the value shown in the example
# is the default the app falls back to.  Paths may be absolute or relative;
# relative paths are resolved against EXEC_DIR (the directory holding main.py
# or the frozen executable).

# ---------------------------------------------------------------------------
# FFmpeg / FFprobe
# ---------------------------------------------------------------------------
# Absolute path to the FFmpeg executable.  If unset, the app first looks in
# `<EXEC_DIR>/bin/ffmpeg/ffmpeg.exe` (the portable copy shipped with the
# project) and then falls back to `ffmpeg` on the system PATH.
# QURAN_FFMPEG_EXE=C:\Program Files\ffmpeg\bin\ffmpeg.exe

# Absolute path to the FFprobe executable.  If unset, the app looks in
# `<EXEC_DIR>/bin/ffmpeg/ffprobe.exe` next to FFmpeg, then on PATH.
# QURAN_FFPROBE_EXE=C:\Program Files\ffmpeg\bin\ffprobe.exe

# ---------------------------------------------------------------------------
# Filesystem layout
# ---------------------------------------------------------------------------
# Directory for short-lived files (segment PNGs, video chunks, locked
# download temp files).  Auto-cleans on exit.
# QURAN_TEMP_DIR=temp

# Persistent audio cache (downloaded recitations).  Two sub-limits below.
# QURAN_AUDIO_CACHE_DIR=cache/audio

# Output directory (final mp4s, background thumbs).  Two sub-dirs are created
# automatically: `video/` and `bg_cache/`.
# QURAN_OUT_DIR=outputs

# Directory containing .ttf / .otf font files scanned at startup.
# QURAN_FONT_DIR=fonts

# Directory containing the per-style background image packs (e.g. `night/`,
# `ramadan/`).  Bundled with the app; only override if you ship a custom pack.
# QURAN_VISION_DIR=vision

# Path to the UI HTML file.  Bundled with the app; rarely overridden.
# QURAN_UI_PATH=UI.html

# ---------------------------------------------------------------------------
# Output resolution
# ---------------------------------------------------------------------------
# Target canvas width / height in pixels.  Defaults are Instagram Reels
# 9:16 portrait (1080 x 1920).  Change both together to keep the aspect ratio.
# QURAN_TARGET_W=1080
# QURAN_TARGET_H=1920

# ---------------------------------------------------------------------------
# Audio cache tuning
# ---------------------------------------------------------------------------
# Cache LRU eviction triggers when EITHER limit is exceeded.  Default 500 MB /
# 1000 files is fine for a single user; raise these on a shared cache drive.
# QURAN_AUDIO_CACHE_MAX_SIZE_MB=500
# QURAN_AUDIO_CACHE_MAX_FILES=1000

# ---------------------------------------------------------------------------
# Flask web server
# ---------------------------------------------------------------------------
# Bind host.  Default 127.0.0.1 (loopback only).  Set to 0.0.0.0 to accept
# connections from other devices on the LAN — only do this on a trusted
# network, there is no auth (see P2-7).
# QURAN_FLASK_HOST=127.0.0.1
# QURAN_FLASK_PORT=5000
# QURAN_FLASK_DEBUG=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Path to the rotating runlog file.  Override for centralised log collection.
# QURAN_LOG_PATH=runlog.txt
